    const scores = {};
    players.forEach(p => {
      scores[p.id] = { name: p.name, points: 0, correctPredictions: 0 };
    });

    Object.entries(results).forEach(([matchId, result]) => {
      players.forEach(p => {
        const key = `${p.id}-${matchId}`;
        const prediction = predictions[key];
        if (prediction && prediction === result) {
          scores[p.id].points += 1;
          scores[p.id].correctPredictions += 1;
        }
      });
    });

    return Object.values(scores).sort((a, b) => b.points - a.points);
  };

