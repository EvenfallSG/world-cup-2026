                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Results Tab */}
        {activeTab === 'results' && currentPlayerId && (
          <div className="bg-white/95 rounded-2xl p-8 shadow-2xl">
            <h2 className="text-2xl font-bold text-blue-900 mb-6">Update Match Results</h2>
            <p className="text-gray-600 mb-6 font-semibold">Only one person needs to update results (they'll appear for everyone)</p>
            
            <div className="space-y-8">
              {['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J', 'K', 'L'].map(group => {
                const groupMatchesForGroup = groupMatches.filter(m => m.group === group);
                return (
                  <div key={group}>
                    <h3 className="text-xl font-bold text-blue-900 mb-4">Group {group}</h3>
                    <div className="space-y-3">
                      {groupMatchesForGroup.map(match => (
                        <div key={match.id} className="p-4 bg-blue-50 rounded-lg">
                          <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                            <div className="font-semibold text-blue-900">
                              {match.date}: {match.team1} vs {match.team2}
                            </div>
                            <select
                              value={results[match.id] || ''}
                              onChange={(e) => setResult(match.id, e.target.value)}
                              className="px-4 py-2 border-2 border-blue-300 rounded font-semibold focus:outline-none focus:border-blue-600 md:w-48"
                            >
                              <option value="">No result yet</option>
                              <option value="1">{match.team1} Won</option>
                              <option value="0">Draw</option>
                              <option value="2">{match.team2} Won</option>
                            </select>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Leaderboard Tab */}
        {activeTab === 'leaderboard' && currentPlayerId && (
          <div className="bg-white/95 rounded-2xl p-8 shadow-2xl">
            <div className="flex items-center gap-3 mb-6">
              <BarChart3 className="w-8 h-8 text-yellow-600" />
              <h2 className="text-3xl font-bold text-blue-900">Live Leaderboard</h2>
            </div>

            <div className="overflow-x-auto">
              <table className="w-full">
                <thead>
                  <tr className="border-b-2 border-blue-900">
                    <th className="px-4 py-3 text-left text-blue-900 font-bold">Rank</th>
                    <th className="px-4 py-3 text-left text-blue-900 font-bold">Player</th>
                    <th className="px-4 py-3 text-right text-blue-900 font-bold">Points</th>
                    <th className="px-4 py-3 text-right text-blue-900 font-bold">Correct</th>
                  </tr>
                </thead>
                <tbody>
                  {calculateScores().map((score, idx) => (
                    <tr 
                      key={idx} 
                      className={`${
                        idx === 0 ? 'bg-yellow-100' : idx === 1 ? 'bg-gray-100' : idx === 2 ? 'bg-orange-100' : ''
                      } ${score.name === currentPlayerName ? 'border-l-4 border-blue-600' : ''}`}
                    >
                      <td className="px-4 py-3 font-bold text-blue-900">
                        {idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : idx + 1}
                      </td>
                      <td className="px-4 py-3 font-semibold text-blue-900">{score.name}</td>
                      <td className="px-4 py-3 text-right text-2xl font-bold text-green-600">{score.points}</td>
                      <td className="px-4 py-3 text-right text-blue-900">{score.correctPredictions}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </div>
  );
};

export default WorldCup2026Predictor;
